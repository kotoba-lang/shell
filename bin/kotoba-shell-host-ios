#!/usr/bin/env bash
set -euo pipefail

provider_command=""
args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target) shift 2 ;;
    --provider-command) provider_command="${2:-}"; shift 2 ;;
    --host-arg) args+=("${2:-}"); shift 2 ;;
    --) shift; args+=("$@"); break ;;
    *) args+=("$1"); shift ;;
  esac
done

cat >/dev/null || true

if ! command -v xcrun >/dev/null 2>&1; then
  printf 'xcrun is required for the iOS host runner\n' >&2
  exit 69
fi

if [[ -n "$provider_command" && ${#args[@]} -eq 0 ]]; then
  printf 'ios provider command requires --host-arg command for simctl spawn\n' >&2
  exit 64
fi

if [[ ${#args[@]} -eq 0 ]]; then
  xcrun simctl list devices booted
else
  xcrun simctl spawn booted "${args[@]}"
fi
